# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GEMINI_API_KEY=AI...

# Embedding model: openai-small | openai-large | gemini
DEFAULT_EMBEDDING_MODEL=openai-small

# Qdrant (local)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Qdrant Cloud (si se configura QDRANT_URL, ignora host/port)
# QDRANT_URL=https://xxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-api-key

# Data
EXCEL_PATH=data/properties.xlsx

# Search
SEARCH_TOP_K=10

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
